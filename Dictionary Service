local DictionaryService = {}

DictionaryService.getn = function(dictionary)
	local amountOfItems = 0
	for i, v in pairs(dictionary) do
		print("dictionary item is: " .. i)
		amountOfItems += 1
	end
	return amountOfItems
end

return DictionaryService

